#testname:some graphs from Moriuchi
#

# embedding 6+65_12.embedding
#
emb="embedding:12 { 0: (5, 6, 7), 1: (3, 7, 4), 2: (4, 4, 6, 6), 3: (1, 4, 5, 7), 4: (1, 2, 2, 3), 5: (0, 7, 3, 6), 6: (0, 5, 2, 2), 7: (0, 1, 3, 5) }"
./contour canonifyuptoih --uptoleftright examples/graphs/hG6_2.knot
echo "$emb" | ./contour canonifyuptoih --uptoleftright

